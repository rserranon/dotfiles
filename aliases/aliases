# RDS tunnel helpers (usage: rds-ssm-tunnel <ec2-id> <rds-host> [local-port])
rds-ssm-tunnel() {
  local instance_id="$1" rds_host="$2" local_port="${3:-5432}"
  if [[ -z "$instance_id" || -z "$rds_host" ]]; then
    echo "Usage: rds-ssm-tunnel <ec2-instance-id> <rds-proxy-host> [local-port]"
    return 1
  fi
  aws ssm start-session \
    --target "$instance_id" \
    --document-name AWS-StartPortForwardingSessionToRemoteHost \
    --parameters "{\"host\":[\"$rds_host\"],\"portNumber\":[\"5432\"],\"localPortNumber\":[\"$local_port\"]}"
}

# RDS SSH tunnel (usage: rds-ssh-tunnel <bastion-host> <rds-host> [local-port])
rds-ssh-tunnel() {
  local bastion="$1" rds_host="$2" local_port="${3:-5432}"
  if [[ -z "$bastion" || -z "$rds_host" ]]; then
    echo "Usage: rds-ssh-tunnel <bastion-host> <rds-proxy-host> [local-port]"
    return 1
  fi
  ssh -N -L "$local_port":"$rds_host":5432 "$bastion"
}

