# Safe delete, requires >brew install trash
alias rm="trash -v"
alias "sudo rm"="sudo trash"

# Unix
alias la="lsd -la"
alias ls="lsd"
alias lt="lsd --tree"
alias tlf="tail -f"
alias ln='ln -v'
alias mkdir='mkdir -p'
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'
alias -g G='| grep'
alias -g M='| less'
alias -g ONE="| awk '{ print \$1}'"

alias :w="echo this isn\'t vim 🌟"
alias :q="echo this isn\'t vim 🌟"

# Bat & Cat
alias cat='bat -p'

# Rust
alias cwr="cargo watch -q -c -w src/ -x 'run -q'"

# git
alias g='git'
alias gs='git status -sb'
alias gl='git log --oneline'
alias gd='git diff'
alias gco='git checkout'
alias gp='git push'
alias gpl='git pull'

# Config Files
alias zshrc="nvim ~/dotfiles/zsh/.zshrc"
alias tmuxconf="nvim ~/.config/tmux/tmux.conf"

# Bitcoin
alias btcreg="$(echo $HOME)/bitcoin-core/bitcoin/src/bitcoind -regtest"
alias btc-qt="$(echo $HOME)/bitcoin-core/bitcoin/src/qt/bitcoin-qt -regtest"
alias clireg="$(echo $HOME)/bitcoin-core/bitcoin/src/bitcoin-cli -regtest"
alias btcsig="$(echo $HOME)/bitcoin-core/bitcoin/src/bitcoind -signet"
alias btcs-qt="$(echo $HOME)/bitcoin-core/bitcoin/src/qt/bitcoin-qt -signet"
alias clisig="$(echo $HOME)/bitcoin-core/bitcoin/src/bitcoin-cli -signet"

# AI tools
alias copilot="gh copilot"
alias gcs="gh copilot suggest"
alias gce="gh copilot explain"
